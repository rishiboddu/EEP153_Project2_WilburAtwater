    "# helper function to determine the right age group\n",
    "def age_bucket(age):\n",
    "    age = float(age)\n",
    "    if age <= 3:\n",
    "        return \"C 1-3\"\n",
    "    elif age <= 8:\n",
    "        return \"4-8\"\n",
    "    elif age <= 13:\n",
    "        return \"9-13\"\n",
    "    elif age <= 18:\n",
    "        return \"14-18\"\n",
    "    elif age <= 30:\n",
    "        return \"19-30\"\n",
    "    elif age <= 50:\n",
    "        return \"31-50\"\n",
    "    else:\n",
    "        return \"51+\""
   ]
